{
  "name": "devhub-ai-command-center",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "prepare": "husky",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "npm run prisma:generate --workspace @devhub/database && turbo run typecheck"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,yml,yaml,md,css}": "prettier --check",
    "*.{js,mjs,cjs,ts,tsx}": "eslint"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "turbo": "2.9.16",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "argon2@0.44.0": true,
    "esbuild@0.28.0": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true
  }
}
