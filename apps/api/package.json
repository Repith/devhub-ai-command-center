{
  "name": "@devhub/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src test",
    "start": "node dist/main.js",
    "test": "vitest run --exclude test/**/*.integration.test.ts",
    "test:integration": "vitest run test/auth.integration.test.ts test/agents.integration.test.ts test/chat.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@devhub/ai": "0.0.0",
    "@devhub/contracts": "0.0.0",
    "@devhub/database": "0.0.0",
    "@devhub/domain": "0.0.0",
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.26",
    "argon2": "0.44.0",
    "cookie-parser": "1.4.7",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@devhub/config": "0.0.0",
    "@nestjs/testing": "11.1.26",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "25.9.2",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "tsx": "4.22.4"
  }
}
