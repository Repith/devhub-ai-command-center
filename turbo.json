{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "generate": {
      "outputs": ["src/generated/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "env": [
        "ACCESS_TOKEN_TTL_SECONDS",
        "DATABASE_URL",
        "JWT_AUDIENCE",
        "JWT_ISSUER",
        "JWT_SECRET",
        "REFRESH_COOKIE_SECURE",
        "REFRESH_TOKEN_TTL_SECONDS"
      ],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck", "generate"],
      "outputs": []
    }
  }
}
